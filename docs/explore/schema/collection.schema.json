{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/pokekarten/igentic-iphone/docs/explore/schema/collection.schema.json",
  "title": "Explore Collection",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "slug", "description", "topics"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "featured": {
      "type": "boolean",
      "default": false
    }
  }
}
